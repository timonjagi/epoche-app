{
  "expo": {
    "name": "Époché",
    "slug": "epoche",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "epoche",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0A1A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.toruslabs.epoche",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "We need access to your photos to attach them to journal entries.",
        "NSCameraUsageDescription": "We need access to your camera to take photos for journal entries."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0F0A1A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.toruslabs.epoche"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "We need access to your photos to attach them to journal entries.",
          "cameraPermission": "We need access to your camera to take photos for journal entries."
        }
      ]
    ]
  }
}
